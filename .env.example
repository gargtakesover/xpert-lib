# =============================================================================
# Xpert Configuration — Copy this file to ~/.xpert/.env to customize behavior
# =============================================================================
# All of these are optional and have sensible defaults.
# Values here take precedence over code defaults.

# -----------------------------------------------------------------------
# Core Behavior
# -----------------------------------------------------------------------

# Minimum delay between HTTP requests to Nitter (seconds). Default: 1.0
# Lower values are faster but increase the risk of rate-limiting.
# XPERT_DELAY=1.5

# HTTP proxy for all Nitter requests (e.g. http://proxy:8080). Default: none
# XPERT_PROXY=http://my.proxy:8080

# Automatically restart Nitter containers when not running. Default: true
# Set to 0, false, or no to disable auto-restart and get a warning instead.
# XPERT_AUTO_RESTART=1

# -----------------------------------------------------------------------
# Debugging & Diagnostics
# -----------------------------------------------------------------------

# Enable CSS selector health check on every Nitter fetch (expensive).
# This parses the full HTML on each request to detect selector degradation.
# Only enable when investigating scraping issues. Default: off
# XPERT_SELECTOR_DEBUG=1
